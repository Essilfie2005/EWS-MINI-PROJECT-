# ─────────────────────────────────────
# Dropout EWS Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────

# ── Database ──
# For development (SQLite - no config needed)
# DATABASE_URL=sqlite+aiosqlite:///./data/ews.db

# For production (MySQL via Docker)
# DATABASE_URL=mysql+aiomysql://ews_user:ews_secure_pass_2026@localhost:3306/dropout_ews
MYSQL_ROOT_PASSWORD=ews_root_2026
MYSQL_DATABASE=dropout_ews
MYSQL_USER=ews_user
MYSQL_PASSWORD=ews_secure_pass_2026

# ── Africa's Talking SMS ──
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your_api_key_here
AFRICASTALKING_SENDER_ID=
SMS_ENABLED=false

# ── Risk Threshold ──
# Youden's J statistic will calibrate this during training
# Default used before model is trained
RISK_THRESHOLD=0.5

# ── Security ──
ANONYMISATION_SALT=change_this_to_a_random_secret_salt_2026

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Scheduler ──
ALERT_CRON_HOUR=18
ALERT_CRON_MINUTE=0
